// Prisma schema — mirrors the live Supabase schema (see supabase/migrations/ and
// database/schema.sql). This is the schema-as-code mirror / future ORM.
//
// The app's working typed client today is supabase-js (RLS-aware) + lib/db/database.types.ts.
// Prisma is NOT generated at runtime yet because DATABASE_URL/DIRECT_URL are not set. To
// activate: add those to .env (Supabase -> Settings -> Database -> Connection string), then
//   pnpm dlx prisma db pull   # reconcile this file against the live DB
//   pnpm dlx prisma generate   # emit the typed client
// RLS policies live in SQL migrations (Prisma does not manage them).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum application_status {
  draft
  submitted
  under_review
  interview
  decision
}

enum document_type {
  sop
  study_plan
  personal_statement
}

model University {
  id                      BigInt   @id
  slug                    String   @unique
  name                    String
  city                    String?
  region                  String?
  country                 String?  @default("South Korea")
  type                    String?
  tier_band               String?
  kr_rank_unirank_2026    Int?
  website                 String?
  intl_office_note        String?
  tuition_ug_krw_min      Int?
  tuition_ug_krw_max      Int?
  tuition_ug_usd_min      Int?
  tuition_ug_usd_max      Int?
  tuition_grad_krw_min    Int?
  tuition_grad_krw_max    Int?
  dorm_krw_per_semester   Int?
  dorm_usd_per_semester   Int?
  application_fee_krw     Int?
  living_krw_per_month    Int?
  living_usd_per_month    Int?
  visa_cost_usd           Int?
  offers_english_programs Boolean? @default(true)
  topik_min_undergrad     Int?
  topik_min_grad          Int?
  english_min_ielts       Decimal? @db.Decimal(2, 1)
  english_min_toefl_ibt   Int?
  scholarship_note        String?
  data_confidence         String?  @default("medium")
  verify_before_launch    Boolean? @default(true)
  created_at              DateTime? @default(now()) @db.Timestamptz(6)

  programs          Program[]
  admission_records AdmissionRecord[]

  @@index([tier_band])
  @@map("universities")
}

model Program {
  id                       BigInt   @id
  university_id            BigInt
  name                     String
  field                    String?
  degree_level             String?
  language_of_instruction  String?
  min_gpa_4_0_scale        Decimal? @db.Decimal(3, 2)
  topik_required_level     Int?
  english_min_ielts        Decimal? @db.Decimal(2, 1)
  deadline_spring_intake   String?
  deadline_fall_intake     String?
  tuition_krw_per_semester Int?
  scholarship_notes        String?
  created_at               DateTime? @default(now()) @db.Timestamptz(6)

  university        University         @relation(fields: [university_id], references: [id], onDelete: Cascade)
  admission_records AdmissionRecord[]
  applications      Application[]

  @@index([university_id])
  @@map("programs")
}

model AdmissionRecord {
  id                   BigInt   @id
  program_id           BigInt
  university_id        BigInt?
  applicant_gpa_4_0    Decimal? @db.Decimal(3, 2)
  applicant_lang_test  String?
  applicant_lang_score Decimal? @db.Decimal(4, 1)
  outcome              String?
  year                 Int?
  synthetic            Boolean? @default(true)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)

  program    Program     @relation(fields: [program_id], references: [id], onDelete: Cascade)
  university University? @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@index([program_id])
  @@index([university_id])
  @@map("admission_records")
}

// PK references auth.users(id) in the DB; not modeled here (auth schema is outside Prisma).
model Student {
  id              String   @id @db.Uuid
  email           String?
  full_name       String?
  country         String?
  gpa             Decimal? @db.Decimal(3, 2)
  gpa_scale       Decimal? @default(4.0) @db.Decimal(3, 1)
  language_test   String?
  language_score  Decimal? @db.Decimal(4, 1)
  budget_usd      Int?
  intended_degree String?
  intended_field  String?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  applications Application[]

  @@map("students")
}

model Application {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id        String             @db.Uuid
  program_id        BigInt
  status            application_status @default(draft)
  probability_score Decimal?           @db.Decimal(5, 2)
  probability_band  String?
  notes             String?
  created_at        DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?          @default(now()) @db.Timestamptz(6)

  student   Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  program   Program   @relation(fields: [program_id], references: [id], onDelete: Restrict)
  documents Document[]

  @@index([student_id])
  @@index([program_id])
  @@map("applications")
}

model Document {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id String        @db.Uuid
  type           document_type
  title          String?
  content        String        @default("")
  version        Int           @default(1)
  created_at     DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?     @default(now()) @db.Timestamptz(6)

  application Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id])
  @@map("documents")
}
