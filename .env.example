# Copy to .env.local and fill in the values you have.
# .env.local is git-ignored — NEVER commit real keys or secrets.
# Leave anything blank to keep the app in mock-data mode (it still builds and renders).

# --- Supabase (owner-provisioned) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never exposed to the client. Used by the seed script and admin actions.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude (document generator — M4) ---
ANTHROPIC_API_KEY=

# --- Analytics: PostHog (funnel — M3) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Error monitoring: Sentry ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Email: Resend (status notifications — M5) ---
RESEND_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
